# AI / Model API Keys
ANAKIN_API_KEY="your_anakin_api_key_here"
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# Optional: per-platform Anakin identity UUIDs (from GET /v1/wire/identities)
WIRE_CRED_AMAZON_CREDENTIAL_ID="your_amazon_identity_uuid"
# ANAKIN_CREDENTIAL_ID="default_identity_uuid"

# Vercel KV / Upstash Redis Configuration
# Required for saving and loading pipelines
KV_URL="rediss://default:your_password@your_upstash_url:6379"
KV_REST_API_URL="https://your_upstash_url.upstash.io"
KV_REST_API_TOKEN="your_upstash_rest_api_token"
KV_REST_API_READ_ONLY_TOKEN="your_upstash_read_only_token"

# Application Settings
NEXT_PUBLIC_APP_URL="http://localhost:3000"
